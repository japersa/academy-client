{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ultra-back-98fc6bf42dce.herokuapp.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
